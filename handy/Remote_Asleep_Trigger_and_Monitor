<!DOCTYPE html>
<html>
<head>
    <title>Aida Butler Remote</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
        body { background: #121212; color: #e0e0e0; font-family: 'Segoe UI', sans-serif; padding: 20px; text-align: center; }
        .card { background: #1e1e1e; border-radius: 15px; padding: 30px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); max-width: 400px; margin: auto; }
        button { background: #6200ee; color: white; border: none; padding: 15px 30px; border-radius: 8px; font-size: 18px; font-weight: bold; cursor: pointer; transition: 0.3s; width: 100%; }
        button:disabled { background: #333; color: #777; }
        #status { margin-top: 20px; font-size: 14px; color: #bb86fc; min-height: 20px; }
        #log-output { margin-top: 20px; text-align: left; font-size: 12px; background: #000; padding: 10px; border-radius: 5px; max-height: 200px; overflow-y: auto; display: none; border: 1px solid #333; }
    </style>
</head>
<body>

<div class="card">
    <h2 style="margin-top:0">Vault Ritual</h2>
    <p style="font-size: 0.9em; color: #999;">Trigger Asleep cycle and archive session logs.</p>
    
    <button id="btn" onclick="triggerButler()">Summon Butler</button>
    <div id="status">Ready.</div>
    
    <div id="log-output"></div>
</div>

<script>
    async function triggerButler() {
        const btn = document.getElementById('btn');
        const status = document.getElementById('status');
        const logBox = document.getElementById('log-output');
        
        btn.disabled = true;
        status.innerText = "Butler is waiting 60s for Drive sync...";
        logBox.style.display = "none";
        logBox.innerHTML = "";

        try {
            const response = await fetch("https://aidas-dreams-1054257858103.us-central1.run.app", {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ pin: "183" }) 
            });

            const data = await response.json();
            
            if (data.status === "Success") {
                status.innerText = "✅ Ritual Complete!";
                if (data.log && data.log.length > 0) {
                    logBox.style.display = "block";
                    data.log.forEach(entry => {
                        logBox.innerHTML += `<div>• ${entry}</div>`;
                    });
                } else {
                    status.innerText = "✅ Complete (Inbox was empty).";
                }
            } else {
                status.innerText = "❌ Error: " + (data.message || "Unknown error");
            }
        } catch (err) {
            status.innerText = "❌ Connection Failed.";
            console.error(err);
        } finally {
            btn.disabled = false;
        }
    }
</script>

</body>
</html>
