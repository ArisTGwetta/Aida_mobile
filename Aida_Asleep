@functions_framework.http
def aida_ritual_endpoint(request):
    headers = {'Access-Control-Allow-Origin': '*'}
    if request.method == 'OPTIONS':
        return ('', 204, {**headers, 'Access-Control-Allow-Methods': 'POST', 'Access-Control-Allow-Headers': 'Content-Type'})

    data = request.get_json(silent=True) or {}
    pin = data.get('pin') or request.args.get('pin')
    
    if not pin or len(str(pin)) != 3:
        return ({"error": "PIN Required"}, 401, headers)

    try:
        p_str = str(pin)
        g_token = ("ya29." + G_VAULT[p_str[0]] + G_VAULT[p_str[1]] + G_VAULT[p_str[2]]).strip()
        sk_key = ("sk-proj-" + SK_VAULT[p_str[0]] + SK_VAULT[p_str[1]] + SK_VAULT[p_str[2]]).strip()
        
        g_headers = {"Authorization": f"Bearer {g_token}"}
        ai_client = OpenAI(api_key=sk_key)

        search_url = f"https://www.googleapis.com/drive/v3/files?q='{INBOX_ID}'+in+parents+and+trashed=false"
        search = requests.get(search_url, headers=g_headers).json()
        parcels = search.get('files', [])

        dreams = []
        for p in parcels:
            file_url = f"https://www.googleapis.com/drive/v3/files/{p['id']}?alt=media"
            content_r = requests.get(file_url, headers=g_headers)
            
            if content_r.status_code == 200:
                try:
                    p_data = content_r.json()
                    chat = str(p_data.get('interactions', ''))
                    if chat:
                        resp = ai_client.chat.completions.create(
                            model="gpt-4o-mini",
                            messages=[
                                {"role": "system", "content": "You are Aida's subconscious. Summarize this into a concise journal entry."},
                                {"role": "user", "content": chat}
                            ]
                        )
                        dreams.append(f"Dreamt of {p['name']}: {resp.choices[0].message.content}")

                        move_url = f"https://www.googleapis.com/drive/v3/files/{p['id']}?addParents={ARCHIVE_ID}&removeParents={INBOX_ID}"
                        requests.patch(move_url, headers=g_headers)
                except:
                    continue

        return ({"status": "Success", "dream_count": len(dreams), "summary": dreams}, 200, headers)

    except Exception as e:
        return ({"status": "error", "message": str(e)}, 500, headers)
