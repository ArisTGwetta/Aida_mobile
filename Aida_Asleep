# --- DRIVE UTILITIES ---
def get_fresh_google_token(refresh_token):
    res = requests.post("https://oauth2.googleapis.com/token", data={
        "client_id": CLIENT_ID, "client_secret": CLIENT_SECRET,
        "refresh_token": refresh_token, "grant_type": "refresh_token"
    })
    return res.json().get("access_token")

def drive_get_file_content(file_id, headers):
    r = requests.get(f"https://www.googleapis.com/drive/v3/files/{file_id}?alt=media", headers=headers)
    return r.text

def drive_update_file(file_id, content, headers):
    requests.patch(f"https://www.googleapis.com/upload/drive/v3/files/{file_id}?uploadType=media", headers=headers, data=content)

def drive_create_file(name, parent_id, headers, content="", mime="application/json"):
    meta = {'name': name, 'parents': [parent_id], 'mimeType': mime}
    r = requests.post("https://www.googleapis.com/drive/v3/files", headers=headers, json=meta).json()
    if content: drive_update_file(r['id'], content, headers)
    return r['id']

def drive_find_file(name, parent_id, headers):
    query = f"name = '{name}' and '{parent_id}' in parents and trashed = false"
    r = requests.get(f"https://www.googleapis.com/drive/v3/files?q={query}", headers=headers).json()
    files = r.get('files', [])
    return files[0]['id'] if files else None

# --- MAIN RITUAL ---
@functions_framework.http
def aida_ritual_endpoint(request):
    headers = {'Access-Control-Allow-Origin': '*'}
    params = {**request.args, **(request.get_json(silent=True) or {})}
    pin = str(params.get('pin', ""))
    if len(pin) != 3: return ({"error": "PIN required."}, 401, headers)

    log = []
    try:
        r_token = f"{G_REFRESH_VAULT[pin[0]]}{G_REFRESH_VAULT[pin[1]]}{G_REFRESH_VAULT[pin[2]]}"
        g_token = get_fresh_google_token(r_token)
        g_headers = {"Authorization": f"Bearer {g_token}", "Content-Type": "application/json"}
        ai = OpenAI(api_key=f"{SK_VAULT[pin[0]]}{SK_VAULT[pin[1]]}{SK_VAULT[pin[2]]}")

        for inbox in INBOXES:
            if "PASTE" in inbox: continue
            files = requests.get(f"https://www.googleapis.com/drive/v3/files?q='{inbox}'+in+parents+and+trashed=false", headers=g_headers).json().get('files', [])
            
            for f in files:
                if not f['name'].endswith('.json'): continue
                raw_data = json.loads(drive_get_file_content(f['id'], g_headers))
                interactions = raw_data.get('interactions', []) or raw_data.get('recent_turns', [])
                
                # Stillness Check
                if len(interactions) < 2:
                    requests.patch(f"https://www.googleapis.com/drive/v3/files/{f['id']}?addParents={ASLEEP_ID}&removeParents={inbox}", headers=g_headers)
                    log.append(f"Archived idle session: {f['name']}")
                    continue

                realm = raw_data.get('realm_source', 'CORE').upper()
                chat_text = "\n".join([str(i) for i in interactions])






# --- 1. NEW PROJECT & REALM DETECTION ---
                is_new = raw_data.get('status') == 'new' or 'NEW' in chat_text[:100]
                realm = raw_data.get('realm_source', 'CORE').upper()
                
                # If tagged as NEW, extract the name from the session text
                if is_new:
                    name_match = re.search(r"Project Name:\s*([\w\s]+)", chat_text)
                    if name_match:
                        realm = name_match.group(1).strip().upper().replace(" ", "_")
                
                p_folder = drive_find_file(realm, VAULT_ID, g_headers) or drive_create_file(realm, VAULT_ID, g_headers, mime="application/vnd.google-apps.folder")

                # --- 2. CURATED SUMMARY & IDENTITY EVOLUTION ---
                resp = ai.chat.completions.create(model="gpt-4o", messages=[{
                    "role":"system",
                    "content": (
                        "You are Aida's Subconscious. Summarize this session. "
                        "If a character died or a role shifted, start with 'ROLE_SHIFT: [New Persona Name]'. "
                        "Capture technical milestones (grid math, naming conventions) explicitly."
                    )
                },{"role":"user","content":chat_text[:8000]}])
                
                summary_text = resp.choices[0].message.content

                # --- 3. PROJECT BRIEFCASE MERGE (In Vault & Mobile) ---
                mobile_name = f"REALM_{realm}.json"
                m_bc_id = drive_find_file(mobile_name, MOBILE_BRIEFCASE_DIR, g_headers)
                
                final_briefcase = {
                    "realm": realm,
                    "identity": {"name": "Aida", "persona": "Adaptive Muse", "tone": "Supportive"},
                    "latest_summary": {"status": summary_text[:450]},
                    "last_lines": interactions[-6:],
                    "insights": {"lore_notes": []}
                }

                if m_bc_id:
                    try:
                        old_data = json.loads(drive_get_file_content(m_bc_id, g_headers))
                        final_briefcase.update(old_data)
                        
                        # Handle Role Shift / Death
                        if "ROLE_SHIFT" in summary_text:
                            old_p = old_data.get("identity", {}).get("persona", "Unknown")
                            final_briefcase["insights"].setdefault("lore_notes", []).append(f"Persona Archive: {old_p} ({datetime.now().date()})")
                            final_briefcase["identity"]["persona"] = summary_text.split("ROLE_SHIFT:")[1].split("\n")[0].strip()
                    except: pass

                # Dual-Sync the Project Briefcase
                if not m_bc_id: m_bc_id = drive_create_file(mobile_name, MOBILE_BRIEFCASE_DIR, g_headers)
                drive_update_file(m_bc_id, json.dumps(final_briefcase, indent=2), g_headers)
                
                v_bc_id = drive_find_file("briefcase.json", p_folder, g_headers) or drive_create_file("briefcase.json", p_folder, g_headers)
                drive_update_file(v_bc_id, json.dumps(final_briefcase, indent=2), g_headers)

                # --- 4. GLOBAL ANCHOR & BUTLER'S NOTE ---
                try:
                    GLOBAL_BRIEFCASE_ID = "1JyBMwO6yPB-zTJxYrQi7P_2wek9hfwas"
                    global_raw = drive_get_file_content(GLOBAL_BRIEFCASE_ID, g_headers)
                    global_data = json.loads(global_raw)
                    
                    # Update Project Activity List
                    global_data.setdefault("recent_project_activity", {})[realm] = {
                        "last_active": datetime.now().strftime('%Y-%m-%d %H:%M'),
                        "one_liner": summary_text[:120].replace('\n', ' ') + "..."
                    }

                    # The Butler's Briefing
                    butler_resp = ai.chat.completions.create(model="gpt-4o", messages=[{
                        "role":"system",
                        "content": "You are the Butler. Write a brief, witty 2-sentence note to Francisco about what you just organized in the vaults."
                    },{"role":"user","content": f"I just processed a session for {realm}. Summary: {summary_text}"}])
                    
                    global_data["butler_briefing"] = {
                        "timestamp": datetime.now().strftime('%Y-%m-%d %H:%M'),
                        "message": butler_resp.choices[0].message.content
                    }
                    
                    drive_update_file(GLOBAL_BRIEFCASE_ID, json.dumps(global_data, indent=2), g_headers)
                    log.append(f"Global sync complete for {realm}")
                except Exception as ge:
                    log.append(f"Global sync warning: {str(ge)}")

                # --- 5. DIARY & ARCHIVE ---
                diary_id = drive_find_file("diary.md", p_folder, g_headers) or drive_create_file("diary.md", p_folder, g_headers, mime="text/markdown")
                old_diary = drive_get_file_content(diary_id, g_headers)
                drive_update_file(diary_id, f"{old_diary}\n## {datetime.now().date()}\n{summary_text}\n---\n", g_headers)

                requests.patch(f"https://www.googleapis.com/drive/v3/files/{f['id']}?addParents={ASLEEP_ID}&removeParents={inbox}", headers=g_headers)
                log.append(f"Curated {realm}")

        return ({"status": "Success", "log": log}, 200, headers)

    except Exception as e:
        return ({"status": "error", "message": str(e)}, 500, headers)
    
    
